# ── MongoDB Atlas connection string ──────────────────────
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/shadow-rift

# ── Server port ───────────────────────────────────────────
PORT=5000

# ── Frontend origin for CORS ──────────────────────────────
# Local dev:      http://localhost:5173
# GitHub Pages:   https://YOUR_USERNAME.github.io
CLIENT_ORIGIN=http://localhost:5173
